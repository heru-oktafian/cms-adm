<div class="min-h-screen bg-slate-950 text-white flex items-center justify-center px-6">
  <div class="w-full max-w-md rounded-2xl border border-slate-800 bg-slate-900/80 shadow-2xl p-8">
    <div class="mb-8">
      <p class="text-sm uppercase tracking-[0.3em] text-slate-400">CMS Admin</p>
      <h1 class="mt-3 text-3xl font-semibold text-white">Sign in</h1>
      <p class="mt-2 text-sm text-slate-400">Masuk ke panel admin untuk mengelola konten portfolio.</p>
    </div>

    <% if flash[:notice].present? %>
      <div class="mb-4 rounded-lg border border-emerald-500/30 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-200">
        <%= flash[:notice] %>
      </div>
    <% end %>

    <% if flash.now[:alert].present? %>
      <div class="mb-4 rounded-lg border border-rose-500/30 bg-rose-500/10 px-4 py-3 text-sm text-rose-200">
        <%= flash.now[:alert] %>
      </div>
    <% end %>

    <%= form_with url: admin_login_path, method: :post, class: "space-y-5" do |form| %>
      <div>
        <%= form.label :email, class: "mb-2 block text-sm font-medium text-slate-200" %>
        <%= form.email_field :email, required: true, class: "w-full rounded-xl border border-slate-700 bg-slate-950 px-4 py-3 text-white outline-none ring-0 focus:border-sky-500", placeholder: "admin@cms.local" %>
      </div>

      <div>
        <%= form.label :password, class: "mb-2 block text-sm font-medium text-slate-200" %>
        <%= form.password_field :password, required: true, class: "w-full rounded-xl border border-slate-700 bg-slate-950 px-4 py-3 text-white outline-none ring-0 focus:border-sky-500", placeholder: "••••••••" %>
      </div>

      <%= form.submit "Login", class: "w-full rounded-xl bg-sky-500 px-4 py-3 font-medium text-slate-950 transition hover:bg-sky-400" %>
    <% end %>
  </div>
</div>
