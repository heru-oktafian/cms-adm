<% profile_data = @form_values || (@data[:raw].is_a?(Hash) ? @data[:raw] : {}) %>

<div class="min-h-screen bg-slate-100 text-slate-900 lg:flex">
  <aside class="relative overflow-hidden bg-slate-950 text-white lg:w-72 xl:w-80">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(56,189,248,0.18),_transparent_48%)]"></div>
    <div class="relative flex h-full flex-col px-5 py-6 sm:px-6 lg:px-6 xl:px-8">
      <div class="mb-8 flex items-center gap-3">
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-sky-500/20 p-2 ring-1 ring-white/10 shadow-[0_8px_20px_rgba(14,165,233,0.18)]">
          <%= image_tag "/icon.png", alt: "cms-adm logo", class: "h-7 w-7 object-contain" %>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.35em] text-sky-200/70">cms-adm</p>
          <p class="mt-1 text-sm text-slate-300">Portfolio control panel</p>
        </div>
      </div>

      <nav class="space-y-2">
        <% navigation_items.each do |item| %>
          <% active = active_nav_key == item[:key] %>
          <%= link_to item[:path], class: "flex items-center justify-between rounded-2xl px-4 py-3 text-sm font-medium transition #{active ? 'bg-sky-500 text-slate-950 shadow-lg shadow-sky-500/20' : 'text-slate-300 hover:bg-white/5 hover:text-white'}" do %>
            <span><%= item[:label] %></span>
            <span class="h-2 w-2 rounded-full <%= active ? 'bg-slate-950/80' : 'bg-slate-600' %>"></span>
          <% end %>
        <% end %>
      </nav>

      <div class="mt-8 rounded-[24px] border border-white/10 bg-white/5 p-5 backdrop-blur-sm">
        <p class="text-xs uppercase tracking-[0.3em] text-sky-200/70">Profile</p>
        <p class="mt-4 text-2xl font-semibold text-white">Identity editor</p>
        <p class="mt-2 text-sm leading-6 text-slate-300/90">Edit profil utama portfolio lalu simpan langsung ke backend CMS.</p>
      </div>

      <div class="mt-auto pt-8">
        <%= button_to "Logout", logout_path, method: :delete, class: "w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-medium text-white transition hover:bg-white/10" %>
      </div>
    </div>
  </aside>

  <main class="flex-1 px-4 py-4 sm:px-6 sm:py-6 lg:px-8 lg:py-8 xl:px-10">
    <div class="mx-auto max-w-7xl space-y-6">
      <header class="rounded-[28px] border border-slate-200 bg-white px-5 py-5 shadow-[0_20px_60px_rgba(15,23,42,0.06)] sm:px-6 lg:px-8">
        <p class="text-sm font-semibold uppercase tracking-[0.35em] text-sky-600">Profile</p>
        <h1 class="mt-3 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">Profile manager</h1>
        <p class="mt-3 text-sm leading-7 text-slate-500 sm:text-base">Kelola identitas utama yang akan tampil di portfolio publik. Form ini terkoneksi ke endpoint admin profile pada backend.</p>
      </header>

      <section class="grid gap-6 xl:grid-cols-[minmax(0,1.2fr)_360px]">
        <div class="rounded-[28px] border border-slate-200 bg-white p-5 shadow-[0_20px_60px_rgba(15,23,42,0.05)] sm:p-6">
          <div class="mb-5 flex items-center justify-between gap-4">
            <div>
              <p class="text-sm font-semibold uppercase tracking-[0.35em] text-sky-600">Editable form</p>
              <h2 class="mt-2 text-2xl font-semibold text-slate-950">Update profile</h2>
            </div>
            <span class="rounded-full bg-emerald-50 px-3 py-1.5 text-xs font-medium text-emerald-600">Connected</span>
          </div>

          <%= form_with url: update_admin_profile_path, method: :patch, scope: :profile, class: "space-y-5" do |f| %>
            <div class="grid gap-8 md:grid-cols-2 md:gap-10 xl:gap-12">
              <div class="space-y-5">
                <div>
                  <%= f.label :full_name, "Full name", class: "mb-2 block text-sm font-medium text-slate-700" %>
                  <%= f.text_field :full_name, value: profile_data["full_name"], class: "w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800 outline-none transition focus:border-sky-500 focus:bg-white focus:ring-4 focus:ring-sky-100" %>
                </div>

                <div>
                  <%= f.label :sub_headline, "Sub headline", class: "mb-2 block text-sm font-medium text-slate-700" %>
                  <%= f.text_field :sub_headline, value: profile_data["sub_headline"], class: "w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800 outline-none transition focus:border-sky-500 focus:bg-white focus:ring-4 focus:ring-sky-100" %>
                </div>

                <div>
                  <%= f.label :hero_description, "Hero description", class: "mb-2 block text-sm font-medium text-slate-700" %>
                  <%= f.text_area :hero_description, value: profile_data["hero_description"], rows: 5, class: "w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800 outline-none transition focus:border-sky-500 focus:bg-white focus:ring-4 focus:ring-sky-100" %>
                </div>

                <div>
                  <%= f.label :email, class: "mb-2 block text-sm font-medium text-slate-700" %>
                  <%= f.email_field :email, value: profile_data["email"], class: "w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800 outline-none transition focus:border-sky-500 focus:bg-white focus:ring-4 focus:ring-sky-100" %>
                </div>

                <div>
                  <%= f.label :location, class: "mb-2 block text-sm font-medium text-slate-700" %>
                  <%= f.text_field :location, value: profile_data["location"], class: "w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800 outline-none transition focus:border-sky-500 focus:bg-white focus:ring-4 focus:ring-sky-100" %>
                </div>

                <div>
                  <%= f.label :resume_path, "Resume path", class: "mb-2 block text-sm font-medium text-slate-700" %>
                  <%= f.text_field :resume_path, value: profile_data["resume_path"], class: "w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800 outline-none transition focus:border-sky-500 focus:bg-white focus:ring-4 focus:ring-sky-100" %>
                </div>
              </div>

              <div class="space-y-5 md:pl-2 xl:pl-3">
                <div>
                  <%= f.label :headline, class: "mb-2 block text-sm font-medium text-slate-700" %>
                  <%= f.text_field :headline, value: profile_data["headline"], class: "w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800 outline-none transition focus:border-sky-500 focus:bg-white focus:ring-4 focus:ring-sky-100" %>
                </div>

                <div>
                  <%= f.label :about_description, "About description", class: "mb-2 block text-sm font-medium text-slate-700" %>
                  <%= f.text_area :about_description, value: profile_data["about_description"], rows: 6, class: "w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800 outline-none transition focus:border-sky-500 focus:bg-white focus:ring-4 focus:ring-sky-100" %>
                </div>

                <div>
                  <%= f.label :phone, class: "mb-2 block text-sm font-medium text-slate-700" %>
                  <%= f.text_field :phone, value: profile_data["phone"], class: "w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800 outline-none transition focus:border-sky-500 focus:bg-white focus:ring-4 focus:ring-sky-100" %>
                </div>

                <div>
                  <%= f.label :avatar_path, "Avatar path", class: "mb-2 block text-sm font-medium text-slate-700" %>
                  <%= f.text_field :avatar_path, value: profile_data["avatar_path"], class: "w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800 outline-none transition focus:border-sky-500 focus:bg-white focus:ring-4 focus:ring-sky-100" %>
                </div>
              </div>
            </div>

            <div class="flex flex-wrap items-center gap-3 pt-2">
              <%= f.submit "Save profile", class: "rounded-2xl bg-slate-950 px-5 py-3 text-sm font-medium text-white shadow-[0_14px_30px_rgba(15,23,42,0.18)] transition hover:bg-slate-800" %>
              <%= link_to "Back to dashboard", dashboard_path, class: "rounded-2xl border border-slate-200 px-5 py-3 text-sm font-medium text-slate-700 transition hover:bg-slate-50" %>
            </div>
          <% end %>
        </div>

        <div class="space-y-6">
          <div class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-[0_20px_60px_rgba(15,23,42,0.05)]">
            <p class="text-sm font-semibold uppercase tracking-[0.35em] text-sky-600">Live snapshot</p>
            <h2 class="mt-2 text-2xl font-semibold text-slate-950">Current backend data</h2>
            <div class="mt-5 space-y-3 text-sm text-slate-600">
              <div class="rounded-2xl bg-slate-50 px-4 py-3">
                <p class="text-xs uppercase tracking-[0.24em] text-slate-400">Name</p>
                <p class="mt-2 font-medium text-slate-900"><%= profile_data["full_name"].presence || "-" %></p>
              </div>
              <div class="rounded-2xl bg-slate-50 px-4 py-3">
                <p class="text-xs uppercase tracking-[0.24em] text-slate-400">Headline</p>
                <p class="mt-2 font-medium text-slate-900"><%= profile_data["headline"].presence || "-" %></p>
              </div>
              <div class="rounded-2xl bg-slate-50 px-4 py-3">
                <p class="text-xs uppercase tracking-[0.24em] text-slate-400">Hero description</p>
                <p class="mt-2 font-medium text-slate-900"><%= profile_data["hero_description"].presence || "-" %></p>
              </div>
              <div class="rounded-2xl bg-slate-50 px-4 py-3">
                <p class="text-xs uppercase tracking-[0.24em] text-slate-400">About description</p>
                <p class="mt-2 font-medium text-slate-900"><%= profile_data["about_description"].presence || "-" %></p>
              </div>
              <div class="rounded-2xl bg-slate-50 px-4 py-3">
                <p class="text-xs uppercase tracking-[0.24em] text-slate-400">Email</p>
                <p class="mt-2 font-medium text-slate-900"><%= profile_data["email"].presence || "-" %></p>
              </div>
              <div class="rounded-2xl bg-slate-50 px-4 py-3">
                <p class="text-xs uppercase tracking-[0.24em] text-slate-400">Location</p>
                <p class="mt-2 font-medium text-slate-900"><%= profile_data["location"].presence || "-" %></p>
              </div>
            </div>
          </div>

          <div class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-[0_20px_60px_rgba(15,23,42,0.05)]">
            <p class="text-sm font-semibold uppercase tracking-[0.35em] text-sky-600">API target</p>
            <div class="mt-5 rounded-2xl bg-slate-50 px-4 py-4 text-sm text-slate-700">
              <code class="break-all"><%= @resource[:endpoint] %></code>
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>
</div>
