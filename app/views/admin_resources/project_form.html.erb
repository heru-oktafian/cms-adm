<% project = @project || {} %>
<% editing = @project_form_mode == :edit %>

<div class="min-h-screen bg-slate-100 text-slate-900 lg:flex">
  <aside class="relative overflow-hidden bg-slate-950 text-white lg:w-72 xl:w-80">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(56,189,248,0.18),_transparent_48%)]"></div>
    <div class="relative flex h-full flex-col px-5 py-6 sm:px-6 lg:px-6 xl:px-8">
      <div class="mb-8 flex items-center gap-3">
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-sky-500/20 p-2 ring-1 ring-white/10 shadow-[0_8px_20px_rgba(14,165,233,0.18)]">
          <%= image_tag "/icon.png", alt: "cms-adm logo", class: "h-7 w-7 object-contain" %>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.35em] text-sky-200/70">cms-adm</p>
          <p class="mt-1 text-sm text-slate-300">Portfolio control panel</p>
        </div>
      </div>
      <nav class="space-y-2">
        <% navigation_items.each do |item| %>
          <% active = active_nav_key == item[:key] %>
          <%= link_to item[:path], class: "flex items-center justify-between rounded-2xl px-4 py-3 text-sm font-medium transition #{active ? 'bg-sky-500 text-slate-950 shadow-lg shadow-sky-500/20' : 'text-slate-300 hover:bg-white/5 hover:text-white'}" do %>
            <span><%= item[:label] %></span>
            <span class="h-2 w-2 rounded-full <%= active ? 'bg-slate-950/80' : 'bg-slate-600' %>"></span>
          <% end %>
        <% end %>
      </nav>
      <div class="mt-auto pt-8">
        <%= button_to "Logout", logout_path, method: :delete, class: "w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-medium text-white transition hover:bg-white/10" %>
      </div>
    </div>
  </aside>

  <main class="flex-1 px-4 py-4 sm:px-6 sm:py-6 lg:px-8 lg:py-8 xl:px-10">
    <div class="mx-auto max-w-5xl space-y-6">
      <header class="rounded-[28px] border border-slate-200 bg-white px-5 py-5 shadow-[0_20px_60px_rgba(15,23,42,0.06)] sm:px-6 lg:px-8">
        <p class="text-sm font-semibold uppercase tracking-[0.35em] text-sky-600">Projects</p>
        <h1 class="mt-3 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl"><%= editing ? 'Edit project' : 'Create project' %></h1>
        <p class="mt-3 text-sm leading-7 text-slate-500 sm:text-base">Isi form project lalu simpan ke backend CMS melalui admin panel.</p>
      </header>

      <div class="rounded-[28px] border border-slate-200 bg-white p-5 shadow-[0_20px_60px_rgba(15,23,42,0.05)] sm:p-6">
        <%= form_with url: editing ? update_admin_project_path(project["id"] || project[:id]) : create_admin_project_path, method: editing ? :patch : :post, scope: :project, class: "space-y-5" do |f| %>
          <div class="grid gap-5 md:grid-cols-2">
            <div>
              <%= f.label :title, class: "mb-2 block text-sm font-medium text-slate-700" %>
              <%= f.text_field :title, value: project["title"] || project[:title], class: "w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800" %>
            </div>
            <div>
              <%= f.label :slug, class: "mb-2 block text-sm font-medium text-slate-700" %>
              <%= f.text_field :slug, value: project["slug"] || project[:slug], class: "w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800" %>
            </div>
            <div class="md:col-span-2">
              <%= f.label :summary, class: "mb-2 block text-sm font-medium text-slate-700" %>
              <%= f.text_field :summary, value: project["summary"] || project[:summary], class: "w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800" %>
            </div>
            <div class="md:col-span-2">
              <%= f.label :description, class: "mb-2 block text-sm font-medium text-slate-700" %>
              <%= f.text_area :description, value: project["description"] || project[:description], rows: 5, class: "w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800" %>
            </div>
            <div>
              <%= f.label :thumbnail_path, "Thumbnail path", class: "mb-2 block text-sm font-medium text-slate-700" %>
              <%= f.text_field :thumbnail_path, value: project["thumbnail_path"] || project[:thumbnail_path], class: "w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800" %>
            </div>
            <div>
              <%= f.label :sort_order, class: "mb-2 block text-sm font-medium text-slate-700" %>
              <%= f.number_field :sort_order, value: project["sort_order"] || project[:sort_order] || 0, class: "w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800" %>
            </div>
            <div>
              <%= f.label :project_url, class: "mb-2 block text-sm font-medium text-slate-700" %>
              <%= f.url_field :project_url, value: project["project_url"] || project[:project_url], class: "w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800" %>
            </div>
            <div>
              <%= f.label :repo_url, class: "mb-2 block text-sm font-medium text-slate-700" %>
              <%= f.url_field :repo_url, value: project["repo_url"] || project[:repo_url], class: "w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800" %>
            </div>
            <div class="md:col-span-2">
              <label class="inline-flex items-center gap-3 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700">
                <%= f.check_box :is_featured, { checked: project["is_featured"] || project[:is_featured] }, true, false %>
                <span>Featured project</span>
              </label>
            </div>
          </div>
          <div class="flex flex-wrap gap-3">
            <%= f.submit(editing ? "Update project" : "Create project", class: "rounded-2xl bg-slate-950 px-5 py-3 text-sm font-medium text-white") %>
            <%= link_to "Back to projects", admin_resource_path("projects"), class: "rounded-2xl border border-slate-200 px-5 py-3 text-sm font-medium text-slate-700" %>
          </div>
        <% end %>
      </div>
    </div>
  </main>
</div>
