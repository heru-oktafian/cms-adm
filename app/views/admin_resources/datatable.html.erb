            const activeField = document.getElementById('social-link-active-field');

            document.querySelectorAll('[data-social-link-edit]').forEach((button) => {
              button.addEventListener('click', function () {
                const socialLink = JSON.parse(button.dataset.socialLinkPayload);
                form.dataset.mode = 'edit';
                form.dataset.action = `${root.dataset.socialLinkUpdateBase}/${socialLink.id}`;
                if (title) title.textContent = 'Edit Social Link';
                if (submit) submit.textContent = 'Update Social Link';
                if (platformField) platformField.value = socialLink.platform || '';
                if (labelField) labelField.value = socialLink.label || '';
                if (urlField) urlField.value = socialLink.url || '';
                if (iconField) iconField.value = socialLink.icon_path || '';
                if (sortField) sortField.value = socialLink.sort_order || 0;
                if (activeField) activeField.checked = !!socialLink.is_active;
                if (feedback) feedback.classList.add('hidden');
                modal.classList.remove('hidden');
              });
            });

            form.addEventListener('submit', async function (event) {
              event.preventDefault();
              const formData = new FormData(form);
              const method = form.dataset.mode === 'edit' ? 'PATCH' : 'POST';
              const action = form.dataset.mode === 'edit' ? form.dataset.action : root.dataset.socialLinkCreatePath;
              try {
                const response = await fetch(action, {
                  method,
                  headers: {
                    'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || '',
                    'Accept': 'application/json'
                  },
                  body: formData
                });
                const payload = await response.json();
                if (response.status === 401) {
                  window.location.href = root.dataset.loginPath || '/login';
                  return;
                }
                if (!response.ok) {
                  feedback.textContent = payload.message || 'Gagal menyimpan social link.';
                  feedback.className = 'rounded-2xl px-4 py-3 text-sm bg-rose-50 text-rose-600';
                  feedback.classList.remove('hidden');
                  return;
                }
                window.location.href = '/admin/social_links';
              } catch (error) {
                feedback.textContent = `Gagal mengirim request: ${error.message}`;
                feedback.className = 'rounded-2xl px-4 py-3 text-sm bg-rose-50 text-rose-600';
                feedback.classList.remove('hidden');
              }
            });
          })();
        </script>
        <div id="social-link-delete-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-slate-950/50 px-4">
          <div class="w-full max-w-lg rounded-[28px] bg-white p-6 shadow-2xl">
            <h3 class="text-2xl font-semibold text-slate-950">Delete social link</h3>
            <p id="social-link-delete-text" class="mt-4 text-sm leading-7 text-slate-600">Apakah anda yakin akan menghapus social link ini?</p>
            <div class="mt-6 flex flex-wrap gap-3">
              <button id="social-link-delete-confirm" type="button" class="rounded-2xl bg-rose-600 px-5 py-3 text-sm font-medium text-white">Ya, hapus</button>
              <button type="button" onclick="document.getElementById('social-link-delete-modal').classList.add('hidden')" class="rounded-2xl border border-slate-200 px-5 py-3 text-sm font-medium text-slate-700">Tidak</button>
            </div>
          </div>
        </div>
        <script>
          (function () {
            const root = document.querySelector('[data-social-link-delete-base]');
            if (!root) return;
            const deleteModal = document.getElementById('social-link-delete-modal');
            const deleteText = document.getElementById('social-link-delete-text');
            const deleteConfirm = document.getElementById('social-link-delete-confirm');
            let deleteId = null;
            document.querySelectorAll('[data-social-link-delete]').forEach((button) => {
              button.addEventListener('click', function () {
                const socialLink = JSON.parse(button.dataset.socialLinkPayload);
                deleteId = socialLink.id;
                deleteText.textContent = `Apakah anda yakin akan menghapus Social Link ${socialLink.platform} ini?`;
                deleteModal.classList.remove('hidden');
              });
            });
            deleteConfirm?.addEventListener('click', async function () {
              if (!deleteId) return;
              const response = await fetch(`${root.dataset.socialLinkDeleteBase}/${deleteId}`, {
                method: 'DELETE',
                headers: {
                  'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || '',
                  'Accept': 'application/json'
                }
              });
              if (response.status === 401) {
                window.location.href = root.dataset.loginPath || '/login';
                return;
              }
              window.location.href = '/admin/social_links';
            });
          })();
        </script>
      <% end %>

      <% if @resource_key == 'skills' %>
        <div id="skill-create-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-slate-950/50 px-4">
          <div class="w-full max-w-2xl rounded-[28px] bg-white p-5 shadow-2xl sm:p-6">
            <div class="mb-5 flex items-center justify-between gap-4">
              <h3 class="text-2xl font-semibold text-slate-950">Create Skill</h3>
              <button type="button" onclick="document.getElementById('skill-create-modal').classList.add('hidden')" class="rounded-2xl border border-slate-200 px-3 py-2 text-sm text-slate-600">Close</button>
            </div>
            <form id="skill-create-form" class="space-y-5">
              <div id="skill-create-feedback" class="hidden rounded-2xl px-4 py-3 text-sm"></div>
              <div class="grid gap-5 md:grid-cols-2">
                <div>
                  <label class="mb-2 block text-sm font-medium text-slate-700">Name</label>
                  <input id="skill-name-field" name="skill[name]" type="text" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800">
                </div>
                <div>
                  <label class="mb-2 block text-sm font-medium text-slate-700">Category</label>
                  <input id="skill-category-field" name="skill[category]" type="text" placeholder="Backend & Database" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800">
                </div>
                <div>
                  <label class="mb-2 block text-sm font-medium text-slate-700">Level (%)</label>
                  <input id="skill-level-field" name="skill[level]" type="number" min="0" max="100" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800">
                </div>
                <div>
                  <label class="mb-2 block text-sm font-medium text-slate-700">Sort order</label>
                  <input id="skill-sort-field" name="skill[sort_order]" type="number" value="0" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800">
                </div>
                <div>
                  <label class="inline-flex items-center gap-3 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700">
                    <input id="skill-active-field" name="skill[is_active]" type="checkbox" value="true" checked>
                    <span>Active on public site</span>
                  </label>
                </div>
              </div>
              <div class="mt-6 flex flex-wrap gap-3">
                <button id="skill-create-submit" type="submit" class="rounded-2xl bg-slate-950 px-5 py-3 text-sm font-medium text-white">Create Skill</button>
              <button type="button" onclick="document.getElementById('skill-create-modal').classList.add('hidden')" class="rounded-2xl border border-slate-200 px-5 py-3 text-sm font-medium text-slate-700">Cancel</button>
              </div>
            </form>
          </div>
        </div>
        <script>
          (function () {
            const form = document.getElementById('skill-create-form');
            if (!form || form.dataset.bound === 'true') return;
            form.dataset.bound = 'true';

            const root = document.querySelector('[data-skill-create-path]');
            const feedback = document.getElementById('skill-create-feedback');
            const modal = document.getElementById('skill-create-modal');
            const title = modal?.querySelector('h3');
            const submit = document.getElementById('skill-create-submit');
            const nameField = document.getElementById('skill-name-field');
            const categoryField = document.getElementById('skill-category-field');
            const levelField = document.getElementById('skill-level-field');
            const sortField = document.getElementById('skill-sort-field');
            const activeField = document.getElementById('skill-active-field');

            document.querySelectorAll('[data-skill-edit]').forEach((button) => {
              button.addEventListener('click', function () {
                const skill = JSON.parse(button.dataset.skillPayload);
                form.dataset.mode = 'edit';
                form.dataset.skillId = skill.id;
                form.dataset.action = `${root.dataset.skillUpdateBase}/${skill.id}`;
                if (title) title.textContent = 'Edit Skill';
                if (submit) submit.textContent = 'Update Skill';
                if (nameField) nameField.value = skill.name || '';
                if (categoryField) categoryField.value = skill.category || '';
                if (levelField) levelField.value = skill.level || 0;
                if (sortField) sortField.value = skill.sort_order || 0;
                if (activeField) activeField.checked = !!skill.is_active;
                if (feedback) feedback.classList.add('hidden');
                modal.classList.remove('hidden');
              });
            });

            form.addEventListener('submit', async function (event) {
              event.preventDefault();
              const formData = new FormData(form);
              const mode = form.dataset.mode === 'edit' ? 'PATCH' : 'POST';
              const action = form.dataset.mode === 'edit' ? form.dataset.action : root.dataset.skillCreatePath;
              try {
                const response = await fetch(action, {
                  method: mode,
                  headers: {
                    'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || '',
                    'Accept': 'application/json'
                  },
                  body: formData
                });
                const payload = await response.json();
                if (response.status === 401) {
                  window.location.href = root.dataset.loginPath || '/login';
                  return;
                }
                if (!response.ok) {
                  feedback.textContent = payload.message || 'Gagal menyimpan skill.';
                  feedback.className = 'rounded-2xl px-4 py-3 text-sm bg-rose-50 text-rose-600';
                  feedback.classList.remove('hidden');
                  return;
                }
                window.location.href = '/admin/skills';
              } catch (error) {
                feedback.textContent = `Gagal mengirim request: ${error.message}`;
                feedback.className = 'rounded-2xl px-4 py-3 text-sm bg-rose-50 text-rose-600';
                feedback.classList.remove('hidden');
              }
            });
          })();
        </script>

        <div id="skill-delete-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-slate-950/50 px-4">
          <div class="w-full max-w-lg rounded-[28px] bg-white p-6 shadow-2xl">
            <h3 class="text-2xl font-semibold text-slate-950">Delete skill</h3>
            <p id="skill-delete-text" class="mt-4 text-sm leading-7 text-slate-600">Apakah anda yakin akan menghapus skill ini?</p>
            <div class="mt-6 flex flex-wrap gap-3">
              <button id="skill-delete-confirm" type="button" class="rounded-2xl bg-rose-600 px-5 py-3 text-sm font-medium text-white">Ya, hapus</button>
              <button type="button" onclick="document.getElementById('skill-delete-modal').classList.add('hidden')" class="rounded-2xl border border-slate-200 px-5 py-3 text-sm font-medium text-slate-700">Tidak</button>
            </div>
          </div>
        </div>
        <script>
          (function () {
            const root = document.querySelector('[data-skill-delete-base]');
            if (!root) return;
            const deleteModal = document.getElementById('skill-delete-modal');
            const deleteText = document.getElementById('skill-delete-text');
            const deleteConfirm = document.getElementById('skill-delete-confirm');
            let deleteId = null;
            document.querySelectorAll('[data-skill-delete]').forEach((button) => {
              button.addEventListener('click', function () {
                const skill = JSON.parse(button.dataset.skillPayload);
                deleteId = skill.id;
                deleteText.textContent = `Apakah anda yakin akan menghapus Skill ${skill.name} ini?`;
                deleteModal.classList.remove('hidden');
              });
            });
            deleteConfirm?.addEventListener('click', async function () {
              if (!deleteId) return;
              const response = await fetch(`${root.dataset.skillDeleteBase}/${deleteId}`, {
                method: 'DELETE',
                headers: {
                  'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || '',
                  'Accept': 'application/json'
                }
              });
              if (response.status === 401) {
                window.location.href = root.dataset.loginPath || '/login';
                return;
              }
              window.location.href = '/admin/skills';
            });
          })();
        </script>
      <% end %>

      <% if project_mode %>
        <div data-project-modal class="hidden fixed inset-0 z-50 flex items-center justify-center bg-slate-950/50 px-4">
          <div class="w-full max-w-3xl rounded-[28px] bg-white p-5 shadow-2xl sm:p-6">
            <div class="mb-5 flex items-center justify-between gap-4">
              <h3 data-project-modal-title class="text-2xl font-semibold text-slate-950">Create project</h3>
              <button type="button" data-project-close class="rounded-2xl border border-slate-200 px-3 py-2 text-sm text-slate-600">Close</button>
            </div>
            <form data-project-form action="<%= create_admin_project_path %>" method="post" class="space-y-5">
              <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
              <input data-project-field="id" type="hidden">
              <div data-project-feedback class="hidden"></div>
              <div class="grid gap-5 md:grid-cols-2">
                <div>
                  <label class="mb-2 block text-sm font-medium text-slate-700">Title</label>
                  <input data-project-field="title" name="project[title]" type="text" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800">
                </div>
                <div>
                  <label class="mb-2 block text-sm font-medium text-slate-700">Slug</label>
                  <input data-project-field="slug" name="project[slug]" type="text" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800">
                </div>
                <div class="md:col-span-2">
                  <label class="mb-2 block text-sm font-medium text-slate-700">Summary</label>
                  <input data-project-field="summary" name="project[summary]" type="text" placeholder="Short description for public project card" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800">
                </div>
                <div class="md:col-span-2">
                  <label class="mb-2 block text-sm font-medium text-slate-700">Description</label>
                  <textarea data-project-field="description" name="project[description]" rows="5" placeholder="Long description for detail or future expansion" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800"></textarea>
                </div>
                <div>
                  <label class="mb-2 block text-sm font-medium text-slate-700">Thumbnail path</label>
                  <input data-project-field="thumbnail_path" name="project[thumbnail_path]" type="text" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800">
                </div>
                <div>
                  <label class="mb-2 block text-sm font-medium text-slate-700">Stack items</label>
                  <input data-project-field="stack_items" name="project[stack_items]" type="text" placeholder="NextJS, Golang, PostgreSQL" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800">
                </div>
                <div>
                  <label class="mb-2 block text-sm font-medium text-slate-700">Sort order</label>
                  <input data-project-field="sort_order" name="project[sort_order]" type="number" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800">
                </div>
                <div>
                  <label class="mb-2 block text-sm font-medium text-slate-700">Project URL</label>
                  <input data-project-field="project_url" name="project[project_url]" type="url" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800">
                </div>
                <div>
                  <label class="mb-2 block text-sm font-medium text-slate-700">Repo URL</label>
                  <input data-project-field="repo_url" name="project[repo_url]" type="url" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800">
                </div>
                <div class="md:col-span-2 flex flex-wrap gap-4">
                  <label class="inline-flex items-center gap-3 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700">
                    <input data-project-field="is_featured" name="project[is_featured]" type="checkbox" value="true">
                    <span>Featured project</span>
                  </label>
                  <label class="inline-flex items-center gap-3 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700">
                    <input data-project-field="is_active" name="project[is_active]" type="checkbox" value="true" checked>
                    <span>Active on public site</span>
                  </label>
                </div>
              </div>
              <div class="flex flex-wrap gap-3">
                <button data-project-submit type="submit" class="rounded-2xl bg-slate-950 px-5 py-3 text-sm font-medium text-white">Create project</button>
                <button type="button" data-project-close class="rounded-2xl border border-slate-200 px-5 py-3 text-sm font-medium text-slate-700">Cancel</button>
              </div>
            </form>
          </div>
        </div>

        <div data-project-delete-modal class="hidden fixed inset-0 z-50 flex items-center justify-center bg-slate-950/50 px-4">
          <div class="w-full max-w-lg rounded-[28px] bg-white p-6 shadow-2xl">
            <h3 class="text-2xl font-semibold text-slate-950">Delete project</h3>
            <p data-project-delete-text class="mt-4 text-sm leading-7 text-slate-600">Apakah anda yakin akan menghapus project ini?</p>
            <div class="mt-6 flex flex-wrap gap-3">
              <form data-project-delete-form action="#" method="post">
                <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
                <input type="hidden" name="_method" value="delete">
                <button type="submit" class="rounded-2xl bg-rose-600 px-5 py-3 text-sm font-medium text-white">Ya, hapus</button>
              </form>
              <button type="button" data-project-delete-close class="rounded-2xl border border-slate-200 px-5 py-3 text-sm font-medium text-slate-700">Tidak</button>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </main>
</div>
