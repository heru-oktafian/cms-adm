<%
  columns = case @resource_key
  when "projects"
    [
      ["Title", ->(item) { item["title"].presence || "-" }],
      ["Stack", ->(item) { item["stack_items"].presence || "-" }],
      ["Featured", ->(item) { item["is_featured"] ? "Yes" : "No" }],
      ["Active", ->(item) { item["is_active"] ? "Yes" : "No" }],
      ["Sort", ->(item) { item["sort_order"].presence || 0 }]
    ]
  when "skills"
    [
      ["Name", ->(item) { item["name"].presence || "-" }],
      ["Category", ->(item) { item["category"].presence || "-" }],
      ["Level", ->(item) { item["level"].presence || 0 }],
      ["Active", ->(item) { item["is_active"] ? "Yes" : "No" }],
      ["Sort", ->(item) { item["sort_order"].presence || 0 }]
    ]
  when "social_links"
    [
      ["Platform", ->(item) { item["platform"].presence || "-" }],
      ["Label", ->(item) { item["label"].presence || "-" }],
      ["URL", ->(item) { item["url"].presence || "-" }],
      ["Active", ->(item) { item["is_active"] ? "Yes" : "No" }],
      ["Sort", ->(item) { item["sort_order"].presence || 0 }]
    ]
  when "messages"
    [
      ["Name", ->(item) { item["name"].presence || "-" }],
      ["Email", ->(item) { item["email"].presence || "-" }],
      ["Subject", ->(item) { item["subject"].presence || "-" }],
      ["Status", ->(item) { item["status"].presence || "new" }],
      ["Received", ->(item) { item["created_at"].presence || "-" }]
    ]
  when "tools"
    [
      ["Name", ->(item) { item["name"].presence || "-" }],
      ["Icon", ->(item) { item["icon_path"].presence || "-" }],
      ["URL", ->(item) { item["url"].presence || "-" }],
      ["Active", ->(item) { item["is_active"] ? "Yes" : "No" }],
      ["Sort", ->(item) { item["sort_order"].presence || 0 }]
    ]
  else
    [
      ["Company", ->(item) { item["company"].presence || "-" }],
      ["Position", ->(item) { item["position"].presence || "-" }],
      ["Period", ->(item) { [item["start_date"], (item["is_current"] ? "Present" : item["end_date"])].compact.join(" → ").presence || "-" }],
      ["Current", ->(item) { item["is_current"] ? "Yes" : "No" }],
      ["Active", ->(item) { item["is_active"] ? "Yes" : "No" }],
      ["Sort", ->(item) { item["sort_order"].presence || 0 }]
    ]
  end

  project_mode = @resource_key == "projects"
  generic_filter_mode = %w[skills experiences social_links].include?(@resource_key)
%>

<div class="min-h-screen bg-slate-100 text-slate-900 lg:flex">
  <aside class="relative overflow-hidden bg-slate-950 text-white lg:w-72 xl:w-80">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(56,189,248,0.18),_transparent_48%)]"></div>
    <div class="relative flex h-full flex-col px-5 py-6 sm:px-6 lg:px-6 xl:px-8">
      <div class="mb-8 flex items-center gap-3">
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-sky-500/20 p-2 ring-1 ring-white/10 shadow-[0_8px_20px_rgba(14,165,233,0.18)]">
          <%= image_tag "/icon.png", alt: "cms-adm logo", class: "h-7 w-7 object-contain" %>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.35em] text-sky-200/70">cms-adm</p>
          <p class="mt-1 text-sm text-slate-300">Portfolio control panel</p>
        </div>
      </div>

      <nav class="space-y-2">
        <% navigation_items.each do |item| %>
          <% active = active_nav_key == item[:key] %>
          <%= link_to item[:path], class: "flex items-center justify-between rounded-2xl px-4 py-3 text-sm font-medium transition #{active ? 'bg-sky-500 text-slate-950 shadow-lg shadow-sky-500/20' : 'text-slate-300 hover:bg-white/5 hover:text-white'}" do %>
            <span><%= item[:label] %></span>
            <span class="h-2 w-2 rounded-full <%= active ? 'bg-slate-950/80' : 'bg-slate-600' %>"></span>
          <% end %>
        <% end %>
      </nav>

      <div class="mt-8 rounded-[24px] border border-white/10 bg-white/5 p-5 backdrop-blur-sm">
        <p class="text-xs uppercase tracking-[0.3em] text-sky-200/70"><%= @resource[:title] %></p>
        <p class="mt-4 text-2xl font-semibold text-white">Data table mode</p>
        <p class="mt-2 text-sm leading-6 text-slate-300/90"><%= @resource[:summary] %></p>
      </div>

      <div class="mt-auto pt-8">
        <%= button_to "Logout", logout_path, method: :delete, class: "w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-medium text-white transition hover:bg-white/10" %>
      </div>
    </div>
  </aside>

  <main class="flex-1 px-4 py-4 sm:px-6 sm:py-6 lg:px-8 lg:py-8 xl:px-10">
    <div class="mx-auto max-w-7xl space-y-6"
      <%= project_mode ? 'data-project-search-root data-project-modal-root' : '' %>
      <%= project_mode ? "data-project-create-path=\"#{create_admin_project_path}\" data-project-update-base=\"/admin/projects\" data-project-delete-base=\"/admin/projects\" data-login-path=\"#{login_path}\"".html_safe : '' %>
      <%= @resource_key == 'skills' ? "data-skill-create-path=\"#{create_admin_skill_path}\" data-skill-update-base=\"/admin/skills\" data-skill-delete-base=\"/admin/skills\" data-login-path=\"#{login_path}\"".html_safe : '' %>
      <%= @resource_key == 'experiences' ? "data-experience-create-path=\"#{create_admin_experience_path}\" data-experience-update-base=\"/admin/experiences\" data-experience-delete-base=\"/admin/experiences\" data-login-path=\"#{login_path}\"".html_safe : '' %>
      <%= @resource_key == 'social_links' ? "data-social-link-create-path=\"#{create_admin_social_link_path}\" data-social-link-update-base=\"/admin/social-links\" data-social-link-delete-base=\"/admin/social-links\" data-login-path=\"#{login_path}\"".html_safe : '' %>
      <%= @resource_key == 'tools' ? "data-tool-create-path=\"#{create_admin_tool_path}\" data-tool-update-base=\"/admin/tools\" data-tool-delete-base=\"/admin/tools\" data-login-path=\"#{login_path}\"".html_safe : '' %>
      <%= @resource_key == 'messages' ? "data-contact-message-update-base=\"/admin/contact-messages\" data-login-path=\"#{login_path}\"".html_safe : '' %>
      <%= (generic_filter_mode || @resource_key == 'tools') ? "data-resource-table-root data-resource-mode=\"#{@resource_key}\"".html_safe : '' %>>
      <header class="rounded-[28px] border border-slate-200 bg-white px-5 py-5 shadow-[0_20px_60px_rgba(15,23,42,0.06)] sm:px-6 lg:px-8">
        <p class="text-sm font-semibold uppercase tracking-[0.35em] text-sky-600"><%= @resource[:title] %></p>
        <h1 class="mt-3 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl"><%= @resource[:title] %> data table</h1>
        <p class="mt-3 text-sm leading-7 text-slate-500 sm:text-base">Tampilan list untuk modul <%= @resource[:title] %>. Data ditarik langsung dari backend admin API agar siap dikembangkan ke create, edit, delete, search, dan sorting.</p>

        <% if project_mode %>
          <div class="mt-5 rounded-[24px] border border-slate-200 bg-slate-50 p-4 sm:p-5">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-end">
              <div class="flex-1">
                <label for="project-search" class="mb-2 block text-sm font-medium text-slate-700">Search projects</label>
                <input id="project-search" type="text" placeholder="Cari title, slug, atau deskripsi project..." data-project-search-input class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-800 outline-none transition focus:border-sky-500 focus:ring-4 focus:ring-sky-100">
              </div>
              <div class="grid gap-4 sm:grid-cols-2 lg:w-[320px]">
                <div>
                  <label for="project-featured-filter" class="mb-2 block text-sm font-medium text-slate-700">Featured</label>
                  <select id="project-featured-filter" data-project-featured-filter class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-800 outline-none transition focus:border-sky-500 focus:ring-4 focus:ring-sky-100">
                    <option value="all">All</option>
                    <option value="true">Featured only</option>
                    <option value="false">Non-featured</option>
                  </select>
                </div>
                <div>
                  <label for="project-sort-filter" class="mb-2 block text-sm font-medium text-slate-700">Sort</label>
                  <select id="project-sort-filter" data-project-sort-filter class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-800 outline-none transition focus:border-sky-500 focus:ring-4 focus:ring-sky-100">
                    <option value="latest">Latest update</option>
                    <option value="title">Title A-Z</option>
                    <option value="sort_order">Sort order</option>
                  </select>
                </div>
              </div>
            </div>
            <p data-project-debug class="mt-4 text-xs text-slate-400">Filter debug idle</p>
          </div>
        <% elsif generic_filter_mode || @resource_key == 'tools' %>
          <div class="mt-5 rounded-[24px] border border-slate-200 bg-slate-50 p-4 sm:p-5">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-end">
              <div class="flex-1">
                <label for="resource-search" class="mb-2 block text-sm font-medium text-slate-700">Search <%= @resource[:title].downcase %></label>
                <input id="resource-search" type="text" placeholder="Cari data di modul <%= @resource[:title] %>..." data-resource-search-input class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-800 outline-none transition focus:border-sky-500 focus:ring-4 focus:ring-sky-100">
              </div>
              <div class="w-full lg:w-[220px]">
                <label for="resource-sort-filter" class="mb-2 block text-sm font-medium text-slate-700">Sort</label>
                <select id="resource-sort-filter" data-resource-sort-filter class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-800 outline-none transition focus:border-sky-500 focus:ring-4 focus:ring-sky-100">
                  <option value="latest">Latest update</option>
                  <option value="name">Name A-Z</option>
                  <option value="sort_order">Sort order</option>
                </select>
              </div>
            </div>
            <p data-resource-debug class="mt-4 text-xs text-slate-400">Filter debug idle</p>
          </div>
        <% end %>
      </header>

      <section class="grid gap-6 xl:grid-cols-[minmax(0,1.3fr)_320px]">
        <div class="rounded-[28px] border border-slate-200 bg-white p-5 shadow-[0_20px_60px_rgba(15,23,42,0.05)] sm:p-6">
          <div class="mb-5 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
              <p class="text-sm font-semibold uppercase tracking-[0.35em] text-sky-600">Data table</p>
              <h2 class="mt-2 text-2xl font-semibold text-slate-950">Live <%= @resource[:title] %> records</h2>
            </div>
            <div class="flex items-center gap-3">
              <% if @resource_key == 'projects' %>
                <button type="button" data-project-create class="rounded-2xl bg-slate-950 px-4 py-2.5 text-sm font-medium text-white">Create Project</button>
              <% elsif @resource_key == 'skills' %>
                <button type="button" onclick="document.getElementById('skill-create-modal').classList.remove('hidden')" class="rounded-2xl bg-slate-950 px-4 py-2.5 text-sm font-medium text-white">Create Skill</button>
              <% elsif @resource_key == 'experiences' %>
                <button type="button" onclick="document.getElementById('experience-create-modal').classList.remove('hidden')" class="rounded-2xl bg-slate-950 px-4 py-2.5 text-sm font-medium text-white">Create Experience</button>
              <% elsif @resource_key == 'tools' %>
                <button type="button" onclick="document.getElementById('tool-create-modal').classList.remove('hidden')" class="rounded-2xl bg-slate-950 px-4 py-2.5 text-sm font-medium text-white">Create Tool</button>
              <% elsif @resource_key == 'social_links' %>
                <button type="button" onclick="document.getElementById('social-link-create-modal').classList.remove('hidden')" class="rounded-2xl bg-slate-950 px-4 py-2.5 text-sm font-medium text-white">Create Social Link</button>
              <% end %>
              <span class="rounded-full px-3 py-1.5 text-xs font-medium <%= @data[:status] == :ok ? 'bg-emerald-50 text-emerald-600' : @data[:status] == :pending ? 'bg-amber-50 text-amber-600' : 'bg-rose-50 text-rose-600' %>"><%= @data[:status].to_s.humanize %></span>
            </div>
          </div>

          <div class="overflow-hidden rounded-[24px] border border-slate-200">
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-slate-200 text-sm">
                <thead class="bg-slate-50">
                  <tr>
                    <% columns.each do |label, _| %>
                      <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-[0.24em] text-slate-400 sm:px-5"><%= label %></th>
                    <% end %>
                    <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-[0.24em] text-slate-400 sm:px-5">Action</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-200 bg-white" <%= project_mode ? 'data-project-table-body' : '' %> <%= (generic_filter_mode || @resource_key == 'tools') ? 'data-resource-table-body' : '' %>>
                  <% if @data[:items].present? %>
                    <% @data[:items].each do |item| %>
                      <% generic_title = (item['name'] || item['company'] || item['platform'] || item['title']).to_s.downcase %>
                      <tr class="transition hover:bg-slate-50/80"
                        <%= project_mode ? "data-project-row data-featured=\"#{item['is_featured'] ? 'true' : 'false'}\" data-title=\"#{ERB::Util.html_escape(item['title'].to_s.downcase)}\" data-sort-order=\"#{item['sort_order'].to_i}\" data-updated-at=\"#{ERB::Util.html_escape(item['updated_at'].to_s)}\"" : '' %>
                        <%= (generic_filter_mode || @resource_key == 'tools') ? "data-resource-row data-title=\"#{ERB::Util.html_escape(generic_title)}\" data-sort-order=\"#{item['sort_order'].to_i}\" data-updated-at=\"#{ERB::Util.html_escape(item['updated_at'].to_s)}\"" : '' %>>
                        <% columns.each do |_, renderer| %>
                          <td class="px-4 py-4 align-top text-slate-700 sm:px-5"><%= renderer.call(item) %></td>
                        <% end %>
                        <td class="px-4 py-4 align-top sm:px-5">
                          <% if @resource_key == 'projects' %>
                            <div class="flex flex-wrap gap-2">
                              <button type="button" data-project-edit data-project-payload="<%= ERB::Util.html_escape(item.to_json) %>" class="inline-flex rounded-full bg-sky-50 px-3 py-1 text-xs font-semibold text-sky-600">Edit</button>
                              <button type="button" data-project-delete data-project-payload="<%= ERB::Util.html_escape(item.to_json) %>" class="inline-flex rounded-full bg-rose-50 px-3 py-1 text-xs font-semibold text-rose-600">Delete</button>
                            </div>
                          <% elsif @resource_key == 'skills' %>
                            <div class="flex flex-wrap gap-2">
                              <button type="button" data-skill-edit data-skill-payload="<%= ERB::Util.html_escape(item.to_json) %>" class="inline-flex rounded-full bg-sky-50 px-3 py-1 text-xs font-semibold text-sky-600">Edit</button>
                              <button type="button" data-skill-delete data-skill-payload="<%= ERB::Util.html_escape(item.to_json) %>" class="inline-flex rounded-full bg-rose-50 px-3 py-1 text-xs font-semibold text-rose-600">Delete</button>
                            </div>
                          <% elsif @resource_key == 'experiences' %>
                            <div class="flex flex-wrap gap-2">
                              <button type="button" data-experience-edit data-experience-payload="<%= ERB::Util.html_escape(item.to_json) %>" class="inline-flex rounded-full bg-sky-50 px-3 py-1 text-xs font-semibold text-sky-600">Edit</button>
                              <button type="button" data-experience-delete data-experience-payload="<%= ERB::Util.html_escape(item.to_json) %>" class="inline-flex rounded-full bg-rose-50 px-3 py-1 text-xs font-semibold text-rose-600">Delete</button>
                            </div>
                          <% elsif @resource_key == 'social_links' %>
                            <div class="flex flex-wrap gap-2">
                              <button type="button" data-social-link-edit data-social-link-payload="<%= ERB::Util.html_escape(item.to_json) %>" class="inline-flex rounded-full bg-sky-50 px-3 py-1 text-xs font-semibold text-sky-600">Edit</button>
                              <button type="button" data-social-link-delete data-social-link-payload="<%= ERB::Util.html_escape(item.to_json) %>" class="inline-flex rounded-full bg-rose-50 px-3 py-1 text-xs font-semibold text-rose-600">Delete</button>
                            </div>
                          <% elsif @resource_key == 'tools' %>
                            <div class="flex flex-wrap gap-2">
                              <button type="button" data-tool-edit data-tool-payload="<%= ERB::Util.html_escape(item.to_json) %>" class="inline-flex rounded-full bg-sky-50 px-3 py-1 text-xs font-semibold text-sky-600">Edit</button>
                              <button type="button" data-tool-delete data-tool-payload="<%= ERB::Util.html_escape(item.to_json) %>" class="inline-flex rounded-full bg-rose-50 px-3 py-1 text-xs font-semibold text-rose-600">Delete</button>
                            </div>
                          <% elsif @resource_key == 'messages' %>
                            <div class="flex flex-wrap gap-2">
                              <button type="button" data-contact-message-edit data-contact-message-payload="<%= ERB::Util.html_escape(item.to_json) %>" class="inline-flex rounded-full bg-sky-50 px-3 py-1 text-xs font-semibold text-sky-600">Detail / Follow Up</button>
                            </div>
                          <% else %>
                            <span class="inline-flex rounded-full bg-sky-50 px-3 py-1 text-xs font-semibold text-sky-600">Soon</span>
                          <% end %>
                        </td>
                      </tr>
                    <% end %>
                  <% else %>
                    <tr>
                      <td colspan="<%= columns.length + 1 %>" class="px-4 py-8 text-center text-sm text-slate-500 sm:px-5">Belum ada data untuk modul ini.</td>
                    </tr>
                  <% end %>

                  <% if project_mode && @data[:items].present? %>
                    <tr data-project-empty-state class="hidden">
                      <td colspan="<%= columns.length + 1 %>" class="px-4 py-8 text-center text-sm text-slate-500 sm:px-5">Tidak ada project yang cocok dengan filter saat ini.</td>
                    </tr>
                  <% elsif (generic_filter_mode || @resource_key == 'tools') && @data[:items].present? %>
                    <tr data-resource-empty-state class="hidden">
                      <td colspan="<%= columns.length + 1 %>" class="px-4 py-8 text-center text-sm text-slate-500 sm:px-5">Tidak ada data yang cocok dengan filter saat ini.</td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <div class="space-y-6">
          <div class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-[0_20px_60px_rgba(15,23,42,0.05)]">
            <p class="text-sm font-semibold uppercase tracking-[0.35em] text-sky-600">Endpoint</p>
            <div class="mt-5 rounded-2xl bg-slate-50 px-4 py-4 text-sm text-slate-700">
              <code class="break-all"><%= @resource[:endpoint] %></code>
            </div>
          </div>

          <div class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-[0_20px_60px_rgba(15,23,42,0.05)]">
            <p class="text-sm font-semibold uppercase tracking-[0.35em] text-sky-600">Table plan</p>
            <div class="mt-5 space-y-3 text-sm text-slate-600">
              <div class="rounded-2xl bg-slate-50 px-4 py-3">Tambah tombol create/edit/delete di tahap berikutnya.</div>
              <div class="rounded-2xl bg-slate-50 px-4 py-3">Lanjutkan dengan search, filter, dan pagination kalau data sudah makin banyak.</div>
              <div class="rounded-2xl bg-slate-50 px-4 py-3">Struktur saat ini sudah siap dijadikan basis CRUD table admin.</div>
            </div>
          </div>
        </div>
      </section>

      <% if @resource_key == 'messages' %>
        <div id="contact-message-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-slate-950/50 px-4">
          <div class="w-full max-w-3xl rounded-[28px] bg-white p-5 shadow-2xl sm:p-6">
            <div class="mb-5 flex items-center justify-between gap-4">
              <h3 class="text-2xl font-semibold text-slate-950">Message Detail</h3>
              <button type="button" onclick="document.getElementById('contact-message-modal').classList.add('hidden')" class="rounded-2xl border border-slate-200 px-3 py-2 text-sm text-slate-600">Close</button>
            </div>
            <form id="contact-message-form" class="space-y-5">
              <div id="contact-message-feedback" class="hidden rounded-2xl px-4 py-3 text-sm"></div>
              <input id="contact-message-id-field" type="hidden">
              <div class="grid gap-5 md:grid-cols-2">
                <div>
                  <label class="mb-2 block text-sm font-medium text-slate-700">Name</label>
                  <input id="contact-message-name-field" type="text" readonly class="w-full rounded-2xl border border-slate-200 bg-slate-100 px-4 py-3 text-sm text-slate-800">
                </div>
                <div>
                  <label class="mb-2 block text-sm font-medium text-slate-700">Email</label>
                  <input id="contact-message-email-field" type="text" readonly class="w-full rounded-2xl border border-slate-200 bg-slate-100 px-4 py-3 text-sm text-slate-800">
                </div>
                <div>
                  <label class="mb-2 block text-sm font-medium text-slate-700">Phone</label>
                  <input id="contact-message-phone-field" type="text" readonly class="w-full rounded-2xl border border-slate-200 bg-slate-100 px-4 py-3 text-sm text-slate-800">
                </div>
                <div>
                  <label class="mb-2 block text-sm font-medium text-slate-700">Subject</label>
                  <input id="contact-message-subject-field" type="text" readonly class="w-full rounded-2xl border border-slate-200 bg-slate-100 px-4 py-3 text-sm text-slate-800">
                </div>
                <div class="md:col-span-2">
                  <label class="mb-2 block text-sm font-medium text-slate-700">Message</label>
                  <textarea id="contact-message-body-field" rows="6" readonly class="w-full rounded-2xl border border-slate-200 bg-slate-100 px-4 py-3 text-sm text-slate-800"></textarea>
                </div>
                <div>
                  <label class="mb-2 block text-sm font-medium text-slate-700">Status</label>
                  <select id="contact-message-status-field" name="contact_message[status]" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-800">
                    <option value="new">New</option>
                    <option value="in_progress">In Progress</option>
                    <option value="done">Done</option>
                  </select>
                </div>
                <div class="md:col-span-2">
                  <label class="mb-2 block text-sm font-medium text-slate-700">Follow up notes</label>
                  <textarea id="contact-message-notes-field" name="contact_message[follow_up_notes]" rows="5" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800"></textarea>
                </div>
              </div>
              <div class="flex flex-wrap gap-3">
