        <script>
          (function () {
            const root = document.querySelector('[data-contact-message-update-base]');
            const form = document.getElementById('contact-message-form');
            if (!root || !form || form.dataset.bound === 'true') return;
            form.dataset.bound = 'true';

            const modal = document.getElementById('contact-message-modal');
            const feedback = document.getElementById('contact-message-feedback');
            const idField = document.getElementById('contact-message-id-field');
            const nameField = document.getElementById('contact-message-name-field');
            const emailField = document.getElementById('contact-message-email-field');
            const phoneField = document.getElementById('contact-message-phone-field');
            const subjectField = document.getElementById('contact-message-subject-field');
            const bodyField = document.getElementById('contact-message-body-field');
            const statusField = document.getElementById('contact-message-status-field');
            const notesField = document.getElementById('contact-message-notes-field');

            document.querySelectorAll('[data-contact-message-edit]').forEach((button) => {
              button.addEventListener('click', function () {
                const message = JSON.parse(button.dataset.contactMessagePayload);
                idField.value = message.id || '';
                nameField.value = message.name || '';
                emailField.value = message.email || '';
                phoneField.value = message.phone || '';
                subjectField.value = message.subject || '';
                bodyField.value = message.message || '';
                statusField.value = message.status || 'new';
                notesField.value = message.follow_up_notes || '';
                feedback.classList.add('hidden');
                modal.classList.remove('hidden');
              });
            });

            form.addEventListener('submit', async function (event) {
              event.preventDefault();
              const id = idField.value;
              if (!id) return;
              const formData = new FormData();
              formData.append('contact_message[status]', statusField.value);
              formData.append('contact_message[follow_up_notes]', notesField.value);

              try {
                const response = await fetch(`${root.dataset.contactMessageUpdateBase}/${id}`, {
                  method: 'PATCH',
                  headers: {
                    'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || '',
                    'Accept': 'application/json'
                  },
                  body: formData
                });
                const payload = await response.json();
                if (response.status === 401) {
                  window.location.href = root.dataset.loginPath || '/login';
                  return;
                }
                if (!response.ok) {
                  feedback.textContent = payload.message || 'Gagal memperbarui pesan.';
                  feedback.className = 'rounded-2xl px-4 py-3 text-sm bg-rose-50 text-rose-600';
                  feedback.classList.remove('hidden');
                  return;
                }
                window.location.href = '/admin/messages';
              } catch (error) {
                feedback.textContent = `Gagal mengirim request: ${error.message}`;
                feedback.className = 'rounded-2xl px-4 py-3 text-sm bg-rose-50 text-rose-600';
                feedback.classList.remove('hidden');
              }
            });
          })();
        </script>
      <% end %>

